# Copy to .env for local dev. On Azure, set these as App Service
# "Application settings" (Configuration tab) instead — do NOT commit real secrets.

SHAREPOINT_TENANT_ID=your-tenant-guid
SHAREPOINT_CLIENT_ID=your-app-client-id
SHAREPOINT_CLIENT_SECRET=your-app-client-secret

SHAREPOINT_HOST=your-tenant.sharepoint.com
SITE_NAME=your-bms-site
SITE_NAME1=your-ops-site

LIST_ID_JMS_JOBS=JMS-Jobs
LIST_ID_JMS_RATES=JMS-Rates
LIST_ID_PPL_POSITIONS=PPL-Positions
LIST_ID_JMS_PROJECTS=JMS-Projects
LIST_ID_PPL_PEOPLE=PPL-People
LIST_ID_JMS_CLIENTS=JMS-Clients

# ── Data storage ──────────────────────────────────────────────
# Preferred: Azure Blob Storage (works across restarts/deploys/instances).
# If BLOB_CONNECTION_STRING is set, quote_data.json & quotes.json live in Blob.
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
CONTAINER=your-container-name

# Optional: last-resort "Browse in SharePoint" link shown when a quotes folder
# can't be auto-located. Leave unset to hide the link.
IMS_OPS_URL=https://your-tenant.sharepoint.com/sites/IMS/Operations

# Fallback only (used when BLOB_CONNECTION_STRING is NOT set): local folder.
# QUOTE_DATA_DIR=/home/data
